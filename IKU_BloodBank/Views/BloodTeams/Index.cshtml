@model IEnumerable<IKU_BloodBank.Models.BloodTeam>

@{
    ViewBag.Title = "Index";
}

<h2>Index</h2>

<p>
    @Html.ActionLink("Create New", "Create")
</p>
<table class="table">
    <tr>
        <th class="general-h2">
            @Html.DisplayNameFor(model => model.TeamName)
        </th>
        <th class="general-h2">
            @Html.DisplayNameFor(model => model.Address)
        </th>
        <th class="general-h2">
            @Html.DisplayNameFor(model => model.CityId)
        </th>
        <th class="general-h2">
            @Html.DisplayNameFor(model => model.CityIdArea)
        </th>
        <th class="general-h2">
            @Html.DisplayNameFor(model => model.Town)
        </th>
        <th class="general-h2">
            @Html.DisplayNameFor(model => model.Latitude)
        </th>
        <th class="general-h2">
            @Html.DisplayNameFor(model => model.Longitude)
        </th>
        <th class="general-h2">
            @Html.DisplayNameFor(model => model.Neighbourhood)
        </th>
        <th class="general-h2">
            @Html.DisplayNameFor(model => model.Platelets)
        </th>
        <th class="general-h2">
            @Html.DisplayNameFor(model => model.PhoneNumber)
        </th>
        <th></th>
    </tr>

@foreach (var item in Model) {
    <tr>
        <td>
            @Html.DisplayFor(modelItem => item.TeamName)
        </td>
        <td>
            @Html.DisplayFor(modelItem => item.Address)
        </td>
        <td>
            @Html.DisplayFor(modelItem => item.CityId)
        </td>
        <td>
            @Html.DisplayFor(modelItem => item.CityIdArea)
        </td>
        <td>
            @Html.DisplayFor(modelItem => item.Town)
        </td>
        <td>
            @Html.DisplayFor(modelItem => item.Latitude)
        </td>
        <td>
            @Html.DisplayFor(modelItem => item.Longitude)
        </td>
        <td>
            @Html.DisplayFor(modelItem => item.Neighbourhood)
        </td>
        <td>
            @Html.DisplayFor(modelItem => item.Platelets)
        </td>
        <td>
            @Html.DisplayFor(modelItem => item.PhoneNumber)
        </td>
        <td>
            @Html.ActionLink("Edit", "Edit", new { id=item.Id }) |
            @Html.ActionLink("Details", "Details", new { id=item.Id }) |
            @Html.ActionLink("Delete", "Delete", new { id=item.Id })
        </td>
    </tr>
}

</table>
